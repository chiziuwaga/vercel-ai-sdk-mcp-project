{
  "mcpServers": {
    "magic-mcp": {
      "command": "npx",
      "args": [
        "-y",
        "@smithery/cli@latest",
        "run",
        "@21st-dev/magic-mcp",
        "--config",
        "{\"TWENTY_FIRST_API_KEY\":\"${TWENTY_FIRST_API_KEY}\"}"
      ]
    },
    "mcp-figma": {
      "command": "npx",
      "args": [
        "-y",
        "@smithery/cli@latest",
        "run",
        "@ai-zerolab/mcp-figma",
        "--key",
        "${FIGMA_API_KEY}"
      ]
    },
    "vercel-ai-sdk-mcp": {
      "command": "npx",
      "args": [
        "-y",
        "@smithery/cli@latest",
        "run",
        "chiziuwaga/vercel-ai-sdk-mcp-project",
        "--config",
        "{\"openaiApiKey\":\"${OPENAI_API_KEY}\", \"anthropicApiKey\":\"${ANTHROPIC_API_KEY}\", \"figmaApiKey\":\"${FIGMA_API_KEY}\", \"twentyFirstApiKey\":\"${TWENTY_FIRST_API_KEY}\", \"transportType\":\"stdio\"}"
      ]
    }
  }
} 