{
  "mcpServers": {
    "magic-mcp": {
      "command": "npx",
      "args": [
        "-y",
        "@smithery/cli@latest",
        "run",
        "@21st-dev/magic-mcp",
        "--config",
        "{\"TWENTY_FIRST_API_KEY\":\"${TWENTY_FIRST_API_KEY}\"}"
      ]
    },
    "mcp-figma": {
      "command": "npx",
      "args": [
        "-y",
        "@smithery/cli@latest",
        "run",
        "@ai-zerolab/mcp-figma",
        "--key",
        "${FIGMA_API_KEY}"
      ]
    },
    "vercel-ai-sdk-mcp": {
      "command": "node",
      "args": [
        "dist/index.js"
      ],
      "env": {
        "OPENAI_API_KEY": "${OPENAI_API_KEY}",
        "ANTHROPIC_API_KEY": "${ANTHROPIC_API_KEY}",
        "TRANSPORT_TYPE": "${TRANSPORT_TYPE}",
        "PORT": "${PORT}"
      }
    }
  }
} 